#!/bin/sh
# Test mode differences: both patches change the same file's mode differently
. ${top_srcdir-.}/tests/common.sh

cat << 'EOF' > patch1
diff --git a/file.c b/file.c
old mode 100644
new mode 100755
--- a/file.c
+++ b/file.c
@@ -1,3 +1,3 @@
 #include <stdio.h>
-int main() { return 0; }
+int main() { return 1; }
 /* end */
EOF

cat << 'EOF' > patch2
diff --git a/file.c b/file.c
old mode 100644
new mode 100700
--- a/file.c
+++ b/file.c
@@ -1,3 +1,3 @@
 #include <stdio.h>
-int main() { return 0; }
+int main() { return 2; }
 /* end */
EOF

${INTERDIFF} --fuzzy patch1 patch2 2>errors >output
[ -s errors ] && exit 1
grep -q 'new mode 100755' output || exit 1
grep -q 'new mode 100700' output || exit 1
exit 0
